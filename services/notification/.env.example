APP_NAME=notification-service
APP_PORT=3006
APP_API_PREFIX=api
NODE_ENV=development

# Database
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=multi_tenant_notifications
DATABASE_MAX_CONNECTIONS=100

# Auth
AUTH_JWT_SECRET=your-jwt-secret-key
AUTH_JWT_EXPIRES_IN=7d

# Internal Service Communication
INTERNAL_SERVICE_API_KEY=your-internal-service-api-key

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Multi-Tenant Platform

# SMS
SMS_PROVIDER=twilio
SMS_PROVIDER_KEY=your-sms-provider-key
SMS_PROVIDER_SECRET=your-sms-provider-secret
SMS_FROM_NUMBER=+1234567890

# Push Notifications (FCM)
FCM_PROJECT_ID=your-fcm-project-id
FCM_PRIVATE_KEY=your-fcm-private-key
FCM_CLIENT_EMAIL=your-fcm-client-email
