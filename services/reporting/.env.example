# Application
NODE_ENV=development
APP_PORT=3007
APP_NAME=reporting-service
API_PREFIX=api
BACKEND_DOMAIN=http://localhost:3007

# Database
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=multi_tenant_reporting
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false

# JWT (must match users-management service)
AUTH_JWT_SECRET=your-super-secret-jwt-key-change-in-production
AUTH_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# Service-to-service communication
INTERNAL_SERVICE_API_KEY=internal-service-api-key-change-in-production

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=reporting-service-group

# Other services URLs
USERS_SERVICE_URL=http://localhost:3001
EXPENSE_SERVICE_URL=http://localhost:3002
PAYROLL_SERVICE_URL=http://localhost:3003
INVOICING_SERVICE_URL=http://localhost:3005
