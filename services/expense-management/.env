# Application
NODE_ENV=development
APP_PORT=3002
APP_NAME=expense-management-service
API_PREFIX=api
BACKEND_DOMAIN=http://localhost:3002

# Database
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=multi_tenant_expenses
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false

# JWT (must match users-management service)
AUTH_JWT_SECRET=your-super-secret-jwt-key-change-in-production
AUTH_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# Service-to-service communication
INTERNAL_SERVICE_API_KEY=internal-service-api-key-change-in-production

# Other services URLs
USERS_SERVICE_URL=http://localhost:3001
NOTIFICATION_SERVICE_URL=http://localhost:3006
WORKFLOW_SERVICE_URL=http://localhost:3004
