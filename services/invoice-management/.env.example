# Application
NODE_ENV=development
APP_PORT=3005
APP_NAME=invoice-management-service
API_PREFIX=api
BACKEND_DOMAIN=http://localhost:3005

# Database
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=multi_tenant_invoices
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false

# JWT (must match users-management service)
AUTH_JWT_SECRET=change-me-in-production
AUTH_REFRESH_SECRET=change-me-in-production

# Service-to-service communication
INTERNAL_SERVICE_API_KEY=change-me-in-production

# Other services URLs
USERS_SERVICE_URL=http://localhost:3001
EXPENSE_SERVICE_URL=http://localhost:3002
NOTIFICATION_SERVICE_URL=http://localhost:3006
WORKFLOW_SERVICE_URL=http://localhost:3004
